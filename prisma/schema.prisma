// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}



model Application {
  id                String   @id @default(cuid())
  name              String?
  initiator         String?
  feel              String?
  status            String
  company           String
  recruiterCo       String?
  role              String
  link              String?
  grossSalFrom      Float?   @default(0)
  grossSalTo        Float?   @default(0)
  netSalFrom        Float?   @default(0)
  netSalTo          Float?   @default(0)
  salaryCurrency    String?  @default("EUR")
  salaryPeriod      String?  @default("month")
  salaryRangeSource String?
  jobType           String?
  duration          String?
  mainRecruiter     String?
  recruiterContact  String?
  dateFound         DateTime?
  applicationDate   DateTime?
  locationType      String?
  currentStep       String?
  stepDate          DateTime?
  nextAction        String?
  deadline          DateTime?
  currentInterviewer String?
  interviewType     String?
  currentStepNotes  String?
  notes             String?
  finalFeedback     String?
  steps             String   // JSON stringified: Array<{ type: 'STEP' | 'CONTACT', isStep: boolean, date: DateTime, description: string }>
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
